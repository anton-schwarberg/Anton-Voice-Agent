# =============================================================================
# Beispiel-Konfiguration — bitte als .env kopieren und mit echten Werten füllen.
# .env ist via .gitignore ausgeschlossen und darf NICHT commited werden.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS Lambda — passwordtest.py
# -----------------------------------------------------------------------------
# Passwort, das der Anrufer auf der Login-Seite eingeben muss.
APP_PASSWORD=replace-me

# -----------------------------------------------------------------------------
# AWS Lambda — checktoken.py
# -----------------------------------------------------------------------------
# Die Make.com Custom-Webhook URL des Voice-Agent-Scenarios.
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/<your-webhook-id>

# -----------------------------------------------------------------------------
# Frontend (website/*.html) — Platzhalter, die beim Deploy ersetzt werden
# -----------------------------------------------------------------------------
# Diese Werte sind im Frontend hartkodiert (statisches S3 Hosting).
# Vor dem S3-Upload müssen die Platzhalter <…> ersetzt werden, z.B. via sed,
# einem Build-Step oder manuell. Sie sind hier nur zur Dokumentation gelistet.

# Basis-URL des API Gateway (ohne trailing slash)
API_GATEWAY_URL=https://<your-api-id>.execute-api.<region>.amazonaws.com

# Make.com API-Key (Header x-make-apikey beim Webhook-Call)
MAKE_API_KEY=replace-me

# -----------------------------------------------------------------------------
# Make.com Scenario — Werte, die nach Import des Blueprints gesetzt werden
# -----------------------------------------------------------------------------
# Die Blueprint-Datei enthält Platzhalter wie <VAPI_ASSISTANT_ID>, die nach
# dem Import in den entsprechenden Modul-Einstellungen einzutragen sind.

VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
ELEVENLABS_VOICE_ID=
CV_FILE_ID=
INTERESTS_FILE_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
